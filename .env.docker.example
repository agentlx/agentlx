NODE_ENV=production
HOST=0.0.0.0
PORT=3015

# Dominio publico atendido pelo Nginx Proxy Manager.
APP_ORIGIN=https://api.example.com
AGENTLX_TRUST_PROXY=true
APP_TIME_ZONE=America/Sao_Paulo

# Opcao 1: banco no Docker Compose
POSTGRES_DB=agentlx
POSTGRES_USER=agentlx
POSTGRES_PASSWORD=change-me-db-password

# Opcao 2: app em Docker e banco fora do Docker
# Descomente e ajuste DATABASE_URL somente se o banco estiver fora do Docker Compose.
# Exemplo Linux/rede local: DATABASE_URL=postgresql://agentlx:senha@192.168.1.10:5432/agentlx
# Exemplo Docker Desktop: DATABASE_URL=postgresql://agentlx:senha@host.docker.internal:5432/agentlx
DATABASE_URL=

DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA=
DATABASE_SSL_CA_PATH=
DATABASE_POOL_MAX=10
DATABASE_CONNECT_RETRIES=30
DATABASE_CONNECT_RETRY_DELAY_MS=2000
AGENTLX_PENDING_TOKEN_SECRET=change-me-pending-token-secret
AGENTLX_MFA_ENCRYPTION_SECRET=change-me-mfa-secret-with-at-least-32-chars
AGENTLX_AUDIT_ANCHOR_SECRET=change-me-audit-anchor-secret
AGENTLX_AUDIT_ANCHOR_FILE=
AGENTLX_MFA_ENCRYPTION_SECRET_PREVIOUS=
AGENTLX_MFA_ISSUER=agentlx
AGENTLX_MFA_PENDING_TTL_MINUTES=15
AGENTLX_MFA_SETUP_TTL_MINUTES=15

AGENTLX_SEED_ON_BOOT=false
DATABASE_RUN_MIGRATIONS_ON_BOOT=true
AGENTLX_SESSION_RETENTION_DAYS=30
AGENTLX_EXECUTION_RETENTION_DAYS=180
AGENTLX_INVENTORY_RETENTION_DAYS=90
AGENTLX_NONCE_RETENTION_HOURS=24
AGENTLX_RATE_LIMIT_RETENTION_HOURS=48

# Prefer Docker Secrets in production when possible. See deploy/docker-compose.secrets.yml.
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
# AGENTLX_PENDING_TOKEN_SECRET_FILE=/run/secrets/agentlx_pending_token_secret
# AGENTLX_MFA_ENCRYPTION_SECRET_FILE=/run/secrets/agentlx_mfa_encryption_secret


